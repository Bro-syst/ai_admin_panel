# Backend URL for local Vite proxy. Browser requests to /api are forwarded here.
AI_ADMIN_DEV_API_TARGET=http://127.0.0.1:8008

# Optional API base URL used by the frontend code. Leave empty for local proxy mode.
VITE_API_BASE_URL=

# API request timeout in milliseconds.
VITE_API_TIMEOUT_MS=5000

# Frontend app version sent with requests for backend logs and diagnostics.
VITE_APP_VERSION=admin-panel-local
